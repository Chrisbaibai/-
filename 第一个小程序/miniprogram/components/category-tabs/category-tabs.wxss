.tabs {
  background: #fff;
  padding: 16rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
}
.tabs-scroll {
  white-space: nowrap;
}
.tabs-list {
  display: flex;
  padding: 0 20rpx;
  gap: 16rpx;
}
.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  flex-shrink: 0;
  transition: all 0.2s;
}
.tab-item.active {
  background: #0f3460;
  color: #fff;
}
