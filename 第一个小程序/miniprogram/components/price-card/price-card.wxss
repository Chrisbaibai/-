.price-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.card-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.card-info {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}
.brand-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #0f3460;
  background: #e8eef6;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}
.name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}
.specs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.spec-tag {
  font-size: 20rpx;
  color: #888;
  background: #f5f5f5;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}
.card-price {
  text-align: right;
  flex-shrink: 0;
}
.price {
  font-size: 34rpx;
  font-weight: 700;
  color: #e74c3c;
}
.change {
  font-size: 22rpx;
  margin-top: 4rpx;
}
.source {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}
