.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 200rpx;
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}
.total-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin: 24rpx 0;
}
.total-label {
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
}
.total-price {
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}
.save-section {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
.name-input {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
}
.save-btn {
  background: #0f3460;
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 配件选择弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}
.picker-panel {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 70vh;
  padding-bottom: env(safe-area-inset-bottom);
}
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.picker-title {
  font-size: 30rpx;
  font-weight: 600;
}
.picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}
.picker-list {
  max-height: 55vh;
}
.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.picker-item:active {
  background: #f9f9f9;
}
.picker-item-info {
  flex: 1;
  margin-right: 20rpx;
}
.picker-item-brand {
  font-size: 20rpx;
  color: #0f3460;
  background: #e8eef6;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}
.picker-item-name {
  font-size: 26rpx;
  color: #333;
}
.picker-item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #e74c3c;
  flex-shrink: 0;
}
.picker-loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}
