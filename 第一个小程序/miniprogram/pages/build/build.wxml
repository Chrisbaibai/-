<view class="page">
  <view class="page-title">自定义装机方案</view>

  <!-- 装机槽位列表 -->
  <view class="slots-container">
    <slot-selector
      wx:for="{{slots}}"
      wx:key="key"
      slotKey="{{item.key}}"
      label="{{item.label}}"
      icon="{{item.icon}}"
      selected="{{selected[item.key]}}"
      warning="{{getWarningForSlot(item.key).message}}"
      warningSeverity="{{getWarningForSlot(item.key).severity}}"
      bind:select="onSlotSelect"
      bind:remove="onSlotRemove"
    />
  </view>

  <!-- 总价 -->
  <view class="total-bar">
    <view class="total-label">预估总价</view>
    <view class="total-price">¥{{totalPrice}}</view>
  </view>

  <!-- 保存方案 -->
  <view class="save-section">
    <input class="name-input" placeholder="输入方案名称" value="{{buildName}}" bindinput="onNameInput" />
    <view class="save-btn" bindtap="onSave">保存方案</view>
  </view>

  <!-- 配件选择弹窗 -->
  <view class="picker-mask" wx:if="{{showPicker}}" bindtap="onPickerClose">
    <view class="picker-panel" catchtap="">
      <view class="picker-header">
        <text class="picker-title">选择配件</text>
        <text class="picker-close" bindtap="onPickerClose">✕</text>
      </view>
      <scroll-view scroll-y class="picker-list">
        <block wx:if="{{!pickerLoading}}">
          <view
            class="picker-item"
            wx:for="{{pickerComponents}}"
            wx:key="_id"
            data-id="{{item._id}}"
            bindtap="onPickerSelect"
          >
            <view class="picker-item-info">
              <text class="picker-item-brand">{{item.brand}}</text>
              <text class="picker-item-name">{{item.name}}</text>
            </view>
            <text class="picker-item-price">¥{{item.latestPrice}}</text>
          </view>
        </block>
        <view class="picker-loading" wx:else>加载中...</view>
      </scroll-view>
    </view>
  </view>
</view>
