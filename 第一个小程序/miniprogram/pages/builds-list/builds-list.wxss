.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 用户信息卡 */
.user-card {
  background: #0f3460;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}
.avatar-placeholder {
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-icon {
  font-size: 44rpx;
}
.user-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}
.login-tip {
  font-size: 30rpx;
  color: rgba(255,255,255,0.8);
}

/* 功能按钮区 */
.action-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.action-text {
  font-size: 26rpx;
  color: #333;
}

/* 分区标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* 方案卡片 */
.build-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.build-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.build-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.build-delete {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 8rpx 16rpx;
}
.build-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #e74c3c;
  margin: 8rpx 0;
}
.build-date {
  font-size: 22rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}
.empty-btn {
  display: inline-block;
  background: #0f3460;
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
.login-prompt {
  text-align: center;
  padding: 80rpx 40rpx;
}

/* 客服弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-box {
  background: #fff;
  border-radius: 24rpx;
  width: 560rpx;
  padding: 48rpx 40rpx 32rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}
.modal-phone {
  font-size: 36rpx;
  color: #0f3460;
  text-align: center;
  margin-bottom: 40rpx;
  font-weight: 600;
}
.modal-btns {
  display: flex;
  gap: 20rpx;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.modal-btn.cancel {
  background: #f0f0f0;
  color: #666;
}
.modal-btn.confirm {
  background: #0f3460;
  color: #fff;
}
