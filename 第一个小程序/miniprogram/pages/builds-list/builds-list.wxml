<view class="page">
  <!-- 用户信息区 -->
  <view class="user-card">
    <block wx:if="{{isLogin}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-name">{{userInfo.nickName}}</view>
    </block>
    <block wx:else>
      <view class="avatar avatar-placeholder" bindtap="onLogin">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="login-tip" bindtap="onLogin">点击登录</view>
    </block>
  </view>

  <!-- 功能按钮区 -->
  <view class="action-bar">
    <view class="action-item" bindtap="onShowPhone">
      <text class="action-icon"> </text>
      <text class="action-text">客服</text>
    </view>
    <view class="action-item" bindtap="onRecycleQuote">
      <text class="action-icon"> </text>
      <text class="action-text">回收报价</text>
    </view>
  </view>

  <!-- 方案列表 -->
  <view class="section-title" wx:if="{{isLogin}}">我的装机方案</view>

  <block wx:if="{{isLogin}}">
    <block wx:if="{{!loading}}">
      <block wx:if="{{builds.length > 0}}">
        <view class="build-card" wx:for="{{builds}}" wx:key="_id" bindtap="onBuildTap" data-id="{{item._id}}">
          <view class="build-header">
            <view class="build-name">{{item.name}}</view>
            <view class="build-delete" data-id="{{item._id}}" catchtap="onDelete">删除</view>
          </view>
          <view class="build-price">¥{{item.totalPrice}}</view>
          <view class="build-date">{{item.createdAt}}</view>
        </view>
      </block>
      <view class="empty-state" wx:else>
        <view class="empty-icon"> </view>
        <view class="empty-text">还没有装机方案</view>
        <view class="empty-btn" bindtap="onNewBuild">开始装机</view>
      </view>
    </block>
    <view class="loading" wx:if="{{loading}}">加载中...</view>
  </block>

  <view class="login-prompt" wx:else>
    <view class="empty-text">登录后可查看已保存的装机方案</view>
  </view>

  <!-- 客服弹窗 -->
  <view class="modal-mask" wx:if="{{showPhoneModal}}" bindtap="onClosePhone">
    <view class="modal-box" catchtap="">
      <view class="modal-title">联系客服</view>
      <view class="modal-phone">+86 15737182723</view>
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="onClosePhone">取消</view>
        <view class="modal-btn confirm" bindtap="onCallPhone">拨打</view>
      </view>
    </view>
  </view>
</view>
