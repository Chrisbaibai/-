.page {
  min-height: 100vh;
  background: #f5f5f5;
}
.search-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #fff;
}
.search-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}
.search-btn {
  background: #0f3460;
  color: #fff;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}
.results {
  padding: 16rpx 20rpx;
}
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.hot-tips {
  padding: 20rpx;
}
.hot-tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}
.hot-tips-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 12rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.hot-tip-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
}
.hot-tip-item:active {
  background: #f9f9f9;
}
.hot-tip-rank {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #f5f5f5;
  color: #999;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.hot-rank-top {
  background: #e74c3c;
  color: #fff;
}
.hot-tip-keyword {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.hot-tip-count {
  font-size: 20rpx;
  color: #bbb;
}
