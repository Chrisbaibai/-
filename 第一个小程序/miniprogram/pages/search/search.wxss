.page {
  min-height: 100vh;
  background: #f5f5f5;
}
.search-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #fff;
}
.search-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}
.search-btn {
  background: #0f3460;
  color: #fff;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}
.results {
  padding: 16rpx 20rpx;
}
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}
