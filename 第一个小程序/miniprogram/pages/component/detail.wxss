.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}
.header {
  text-align: center;
  padding: 40rpx 24rpx;
}
.comp-name {
  font-size: 34rpx;
  font-weight: 600;
  margin: 12rpx 0 8rpx;
}
.comp-category {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.comp-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #e74c3c;
}
.comp-source {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}
.spec-list {
  margin-top: 12rpx;
}
.spec-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.spec-label {
  color: #888;
  font-size: 26rpx;
}
.spec-value {
  color: #333;
  font-size: 26rpx;
  font-weight: 500;
}
.chart-canvas {
  width: 100%;
  height: 400rpx;
  margin-top: 12rpx;
}
.platform-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.platform-name {
  font-size: 26rpx;
  color: #666;
}
.platform-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #e74c3c;
}
.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
