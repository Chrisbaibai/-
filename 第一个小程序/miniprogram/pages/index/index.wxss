.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}
.search-bar {
  padding: 16rpx 20rpx;
  background: #fff;
}
.search-input-placeholder {
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  color: #ccc;
  font-size: 26rpx;
}
.hot-entry {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 16rpx 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.hot-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #e74c3c, #f39c12);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.hot-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-right: 12rpx;
}
.hot-desc {
  flex: 1;
  font-size: 24rpx;
  color: #999;
}
.hot-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.list-container {
  padding: 16rpx 20rpx;
}
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}
